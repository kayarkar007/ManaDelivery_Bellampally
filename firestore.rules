rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════
    // Helper Functions
    // ═══════════════════════════════════════════
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVendorRole() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'VENDOR';
    }

    function isRiderRole() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'RIDER';
    }

    // ═══════════════════════════════════════════
    // USERS — Own profile or admin
    // ═══════════════════════════════════════════
    match /users/{userId} {
      allow read: if isSignedIn();
      // New users can only be created as CUSTOMER role
      allow create: if isOwner(userId) && request.resource.data.role == 'CUSTOMER';
      // Users CANNOT change their own 'role' or 'approvalStatus'
      allow update: if isOwner(userId) && 
        request.resource.data.role == resource.data.role &&
        request.resource.data.approvalStatus == resource.data.approvalStatus;
      // Admin can do anything
      allow update: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // VENDORS — Public read, owner/admin write
    // ═══════════════════════════════════════════
    match /vendors/{vendorId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isOwner(vendorId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // PRODUCTS — Public read, vendor owner/admin write
    // ═══════════════════════════════════════════
    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() && 
        (request.resource.data.vendorId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && 
        (resource.data.vendorId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && 
        (resource.data.vendorId == request.auth.uid || isAdmin());
    }

    // ═══════════════════════════════════════════
    // ORDERS — Strict per-role access
    // ═══════════════════════════════════════════
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.vendorId == request.auth.uid ||
        resource.data.riderId == request.auth.uid ||
        (resource.data.status == 'READY' && isRiderRole()) ||
        isAdmin()
      );
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.vendorId == request.auth.uid ||
        resource.data.riderId == request.auth.uid ||
        (resource.data.status == 'READY' && isRiderRole()) ||
        isAdmin()
      );
      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // CATEGORIES — Public read, admin-only write
    // ═══════════════════════════════════════════
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // BANNERS — Public read, admin-only write
    // ═══════════════════════════════════════════
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // COUPONS — Signed-in read, admin-only write
    // ═══════════════════════════════════════════
    match /coupons/{couponId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // PAYOUTS — Owner read, admin write
    // ═══════════════════════════════════════════
    match /payouts/{payoutId} {
      allow read: if isSignedIn() && 
        (resource.data.vendorId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // SETTINGS — Public read, admin-only write
    // ═══════════════════════════════════════════
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // SUPPORT TICKETS — User creates/reads own, admin manages
    // ═══════════════════════════════════════════
    match /tickets/{ticketId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && 
        (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && 
        (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // AUDIT LOGS — Admin-only, immutable
    // ═══════════════════════════════════════════
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // REVIEWS — Public read, customer creates
    // ═══════════════════════════════════════════
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && 
        (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // WALLET TRANSACTIONS — Owner read, system creates during order flow
    // ═══════════════════════════════════════════
    match /wallet_transactions/{txnId} {
      allow read: if isSignedIn() && 
        (resource.data.userId == request.auth.uid || isAdmin());
      // Allow signed-in users to create transactions (wallet deduction during checkout)
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // NOTIFICATIONS — User reads own
    // ═══════════════════════════════════════════
    match /notifications/{notifId} {
      allow read: if isSignedIn() && 
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin() || isVendorRole();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }
  }
}
